<!-- Phone Case Customizer Block - Using App Proxy -->
<!-- No need to set SHOPIFY_APP_URL anymore! App Proxy handles routing -->

<div class="phone-case-customizer-wrapper">
  <!-- Trigger Button - Only show if product has the tag -->
  {% if product.tags contains 'dsn-editable-true' %}
    <button id="customize-phone-case-btn" class="customize-btn">
      🎨 {{ block.settings.button_text }} <span style="color: pink;">●</span>
    </button>
  {% endif %}

  <!-- Modal Container -->
  <div id="phone-case-modal" class="phone-case-modal" style="visibility:hidden;opacity:0;">
    <!-- Prevent page zoom in modal -->
    <style>
      #phone-case-modal {
        touch-action: pan-x pan-y !important;
        -ms-touch-action: pan-x pan-y !important;
      }
      #phone-case-modal * {
        touch-action: inherit !important;
      }
    </style>
    
    <!-- Close button is now created by React component for proper z-index stacking -->
    
    {% comment %} 
      Use variant-specific image for background
      - If variant has featured_image, use it
      - Otherwise fall back to first product image
    {% endcomment %}
    
    {% if product.selected_or_first_available_variant.featured_image %}
      {% assign background_url = product.selected_or_first_available_variant.featured_image | image_url: width: 600 %}
      {% assign product_image_url = product.selected_or_first_available_variant.featured_image | image_url: width: 600 %}
    {% elsif product.images.size > 0 %}
      {% assign background_url = product.images[0] | image_url: width: 600 %}
      {% assign product_image_url = product.images[0] | image_url: width: 600 %}
    {% else %}
      {% assign background_url = 'phone-case.png' | asset_url %}
      {% assign product_image_url = '' %}
    {% endif %}
    
    {% assign frame_url = 'phone-case-frame.png' | asset_url %}
    
    <div id="phone-case-root" 
         data-frame-url="{{ frame_url }}"
         data-phone-case-url="{{ background_url }}"
         data-product-image-url="{{ product_image_url }}"
         data-variant-id="{{ product.selected_or_first_available_variant.id }}"
         data-designs-url="{{ 'pre-design-images.json' | asset_url }}" 
         data-theme-color="{{ block.settings.theme_color }}" 
         data-product-price="{{ product.selected_or_first_available_variant.price | money }}" 
         data-product-compare-price="{{ product.selected_or_first_available_variant.compare_at_price | money }}"></div>
  </div>
</div>

<script>
// Debug: Log product information
console.log('=== PRODUCT DEBUG INFO ===');
console.log('Product object:', {{ product | json }});
console.log('Product title:', '{{ product.title }}');
console.log('Product images count:', {{ product.images.size }});
console.log('Product images:', [
  {% for image in product.images %}
    {
      src: '{{ image.src }}',
      alt: '{{ image.alt }}',
      width: {{ image.width }},
      height: {{ image.height }},
      position: {{ forloop.index }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]);
console.log('Selected variant:', {
  id: '{{ product.selected_or_first_available_variant.id }}',
  title: '{{ product.selected_or_first_available_variant.title }}',
  featured_image: '{{ product.selected_or_first_available_variant.featured_image.src }}',
  price: '{{ product.selected_or_first_available_variant.price | money }}'
});
console.log('Product metafields:', {
  phone_model: '{{ product.metafields.custom.phone_model }}',
  phone_case_frame: '{{ product.metafields.custom.phone_case_frame }}',
  phone_case_background: '{{ product.metafields.custom.phone_case_background }}'
});
console.log('Product tags:', {{ product.tags | json }});
console.log('=========================');
console.log('Data attributes set:');
console.log('  background_url:', '{{ background_url }}');
console.log('  frame_url:', '{{ frame_url }}');
console.log('=========================');

// Listen for Shopify variant change events and update data attributes
(function() {
  const rootElement = document.getElementById('phone-case-root');
  if (!rootElement) return;

  // Store product variants data for quick lookup
  const variantsData = {
    {% for variant in product.variants %}
      '{{ variant.id }}': {
        id: '{{ variant.id }}',
        title: '{{ variant.title }}',
        {% if variant.featured_image %}
          backgroundUrl: '{{ variant.featured_image | image_url: width: 600 }}',
          productImageUrl: '{{ variant.featured_image | image_url: width: 600 }}'
        {% elsif product.images.size > 0 %}
          backgroundUrl: '{{ product.images[0] | image_url: width: 600 }}',
          productImageUrl: '{{ product.images[0] | image_url: width: 600 }}'
        {% else %}
          backgroundUrl: '{{ 'phone-case.png' | asset_url }}',
          productImageUrl: ''
        {% endif %}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  };

  console.log('Variants data loaded:', variantsData);

  // Function to update data attributes when variant changes
  function updateDataAttributes(variantId) {
    const variantData = variantsData[variantId];
    if (variantData) {
      console.log('Updating data attributes for variant:', variantId, variantData);
      rootElement.setAttribute('data-variant-id', variantData.id);
      rootElement.setAttribute('data-phone-case-url', variantData.backgroundUrl);
      rootElement.setAttribute('data-product-image-url', variantData.productImageUrl);
    }
  }

  // Listen for various variant change events
  document.addEventListener('variant:change', function(event) {
    console.log('variant:change event:', event);
    if (event.detail && event.detail.variant && event.detail.variant.id) {
      updateDataAttributes(event.detail.variant.id.toString());
    }
  });

  // Also listen for form changes (variant selector)
  const variantSelectors = document.querySelectorAll('select[name="id"], input[name="id"]');
  variantSelectors.forEach(selector => {
    selector.addEventListener('change', function(e) {
      console.log('Variant selector changed:', e.target.value);
      updateDataAttributes(e.target.value);
    });
  });

  // Listen for radio button changes (common in modern themes)
  const variantRadios = document.querySelectorAll('input[type="radio"][name*="option"]');
  variantRadios.forEach(radio => {
    radio.addEventListener('change', function() {
      // Find the selected variant based on all option selections
      setTimeout(() => {
        const selectedVariantInput = document.querySelector('input[name="id"]:checked, select[name="id"]');
        if (selectedVariantInput) {
          const variantId = selectedVariantInput.value || selectedVariantInput.options[selectedVariantInput.selectedIndex].value;
          console.log('Variant selected via options:', variantId);
          updateDataAttributes(variantId);
        }
      }, 50);
    });
  });
})();
</script>

<script>
// Fetch admin theme color settings and override block setting
(function() {
  const rootElement = document.getElementById('phone-case-root');
  const settingsUrl = window.location.origin + '/apps/customizer/get-settings';
  
  fetch(settingsUrl)
    .then(response => response.json())
    .then(data => {
      if (data.themeColor) {
        // Override the theme color with admin setting
        rootElement.setAttribute('data-theme-color', data.themeColor);
        console.log('Theme color loaded from admin settings:', data.themeColor);
      }
    })
    .catch(error => {
      console.log('Using default theme color from block settings');
    });
})();
</script>

<!-- Note: Ensure your theme has this meta tag in the <head>:
     <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
-->

<style>
  .phone-case-customizer-wrapper {
    margin: 20px 0;
  }

  .customize-btn {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    padding: 15px 30px;
    font-size: 16px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .customize-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
  }

  .customize-btn:active {
    transform: translateY(0);
  }

  .phone-case-modal {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    width: 100vw !important;
    height: 100vh !important;
    z-index: 2147483647 !important;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 0;
    overflow-x: hidden;
    background: rgba(0, 0, 0, 0.95) !important;
  }

  /* Close button is now created by React component - no styles needed here */

  /* No styles for #phone-case-root - let built CSS handle it like localhost */
</style>

<script>
(function() {
  const modal = document.getElementById('phone-case-modal');
  const btn = document.getElementById('customize-phone-case-btn');
  
  if (!modal || !btn) {
    console.error('Modal or button not found:', { modal, btn });
    return;
  }
  
  let reactMounted = false;
  let modalMovedToBody = false;
  
  // Move modal to body on first open to escape theme container
  function ensureModalInBody() {
    if (!modalMovedToBody && modal && modal.parentElement !== document.body) {
      document.body.appendChild(modal);
      modalMovedToBody = true;
    }
  }
  
  // Open modal
  btn.addEventListener('click', function() {
    console.log('Customize button clicked');
    ensureModalInBody();
    modal.style.visibility = 'visible';
    modal.style.opacity = '1';
    document.body.style.overflow = 'hidden';
    
    // Mount React app on first open
    if (!reactMounted && window.React && window.ReactDOM) {
      reactMounted = true;
      // The phone-customizer.js will auto-mount when the element is visible
    }
  });
  
  // Close modal function (called by backdrop click)
  function closeModal() {
    modal.style.visibility = 'hidden';
    modal.style.opacity = '0';
    document.body.style.overflow = '';
    // Unmount React app
    const root = document.getElementById('phone-case-root');
    if (root && window.ReactDOM) {
      window.ReactDOM.unmountComponentAtNode(root);
    }
  }
  
  // Close button is now handled by React component
  // Clicking outside the content area closes modal
  modal.addEventListener('click', function(e) {
    if (e.target === modal) {
      closeModal();
    }
  });
  
  // Handle Add to Cart from customizer
  window.addEventListener('customizer:addToCart', async function(e) {
    const { designId, imageUrl, emptyCaseUrl, designOnlyUrl } = e.detail;
    
    console.log('Add to cart event received:', { designId, imageUrl, emptyCaseUrl, designOnlyUrl });
    
    // Get the current product variant ID
    const variantId = '{{ product.selected_or_first_available_variant.id }}';
    
    console.log('Variant ID:', variantId);
    
    if (!variantId || variantId === '') {
      alert('Please select a product variant first.');
      return;
    }
    
    // Add to Shopify cart
    const formData = {
      items: [{
        id: variantId,
        quantity: 1,
        properties: {
          '_design_id': designId,
          '_main': imageUrl,
          '_image1': emptyCaseUrl,
          '_print-image': designOnlyUrl,
          '_design_link': imageUrl,  // Add link property for easy access
          'Customized': 'Yes',
          'View Design': imageUrl  // User-visible property with link
        },
        // Set the custom image as the line item image
        image: imageUrl
      }]
    };
    
    console.log('Cart add request:', formData);
    
    try {
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });
      
      console.log('Cart add response status:', response.status);
      
      if (response.ok) {
        const data = await response.json();
        console.log('Cart add success:', data);
        
        closeModal();
        
        // Redirect to cart page
        window.location.href = '/cart';
      } else {
        const error = await response.json();
        console.error('Cart add error:', error);
        alert('Failed to add to cart: ' + (error.description || error.message || 'Unknown error'));
      }
    } catch (error) {
      console.error('Failed to add to cart:', error);
      alert('Failed to add to cart. Please try again.');
    }
  });
  
  // Function to replace cart item images with custom design images
  function replaceCartImages() {
    console.log('Attempting to replace cart images...');
    
    // Fetch cart data
    fetch('/cart.js')
      .then(res => res.json())
      .then(cart => {
        console.log('Cart data:', cart);
        
        // Find all cart item images
        const allImages = document.querySelectorAll('img');
        
        cart.items.forEach((item, itemIndex) => {
          // Check if item has custom image property
          const customImageUrl = item.properties?._main || item.properties?.main;
          
          if (customImageUrl) {
            console.log(`Item ${itemIndex} has custom image:`, customImageUrl);
            
            // Try to find the image by matching the product title or variant ID in nearby text
            allImages.forEach(img => {
              // Check if this image is in a cart item container
              const cartItem = img.closest('.cart-item, .cart__item, [data-cart-item], .line-item, cart-item, tr');
              
              if (cartItem) {
                // Check if this cart item contains the product title or variant ID
                const itemText = cartItem.textContent || '';
                const itemHTML = cartItem.innerHTML || '';
                
                // Match by variant ID or product title
                if (itemHTML.includes(item.variant_id) || itemHTML.includes(item.id) || 
                    itemText.includes(item.product_title) || itemText.includes(item.title)) {
                  
                  console.log('Found matching cart item, replacing image');
                  img.src = customImageUrl;
                  img.srcset = customImageUrl;
                  
                  // Also update parent picture element if exists
                  const picture = img.closest('picture');
                  if (picture) {
                    const sources = picture.querySelectorAll('source');
                    sources.forEach(source => {
                      source.srcset = customImageUrl;
                    });
                  }
                }
              }
            });
          }
        });
      })
      .catch(err => console.error('Failed to replace cart images:', err));
  }
  
  // Replace images when cart is updated
  window.addEventListener('cart:updated', replaceCartImages);
  window.addEventListener('cart:refresh', replaceCartImages);
  document.addEventListener('cart:updated', replaceCartImages);
  document.addEventListener('cart:refresh', replaceCartImages);
  document.addEventListener('DOMContentLoaded', replaceCartImages);
  
  // Also replace on page load if on cart page
  if (window.location.pathname === '/cart') {
    // Run multiple times to catch dynamic content
    replaceCartImages();
    setTimeout(replaceCartImages, 500);
    setTimeout(replaceCartImages, 1000);
    setTimeout(replaceCartImages, 2000);
  }
})();
</script>

