<!-- Phone Case Customizer Block - iframe edition -->
<!--
  The customizer opens inside a full-screen <iframe> instead of a modal div.

  Benefits over the old modal approach:
  - The iframe has its own isolated document, so:
      html, body { overscroll-behavior: none; touch-action: none }
    works correctly — the iframe's body IS the scroll container.
    No Shopify theme interference, no passive-listener problem.
  - Pull-down-to-refresh is prevented at the iframe document level.
  - The React app and all its assets are isolated from the theme's JS/CSS.

  Communication: iframe ↔ parent via postMessage.
    iframe → parent : { type: 'customizer:addToCart', detail: {...} }
    iframe → parent : { type: 'customizer:close' }
    parent → iframe : { type: 'customizer:variantChanged', detail: {...} }
-->

{% comment %} ── Variant data ─────────────────────────────────────────────── {% endcomment %}
{% if product.selected_or_first_available_variant.featured_image %}
  {% assign background_url = product.selected_or_first_available_variant.featured_image | image_url: width: 600 %}
  {% assign product_image_url = product.selected_or_first_available_variant.featured_image | image_url: width: 600 %}
{% elsif product.images.size > 0 %}
  {% assign background_url = product.images[0] | image_url: width: 600 %}
  {% assign product_image_url = product.images[0] | image_url: width: 600 %}
{% else %}
  {% assign background_url = 'phone-case.png' | asset_url %}
  {% assign product_image_url = '' %}
{% endif %}

{% comment %} ── Frame URL ────────────────────────────────────────────────── {% endcomment %}
{% assign custom_frame_url = '' %}
{% assign has_custom_frame = false %}
{% for image in product.images %}
  {% assign alt_lower = image.alt | downcase %}
  {% if alt_lower == 'frame' %}
    {% assign custom_frame_url = image | image_url: width: 600 %}
    {% assign has_custom_frame = true %}
    {% break %}
  {% endif %}
{% endfor %}

{% comment %} ── All product image URLs (comma-separated) ──────────────────── {% endcomment %}
{% assign product_image_urls = '' %}
{% for image in product.images %}
  {% assign image_url = image | image_url: width: 600 %}
  {% if forloop.first %}
    {% assign product_image_urls = image_url %}
  {% else %}
    {% assign product_image_urls = product_image_urls | append: ',' | append: image_url %}
  {% endif %}
{% endfor %}

<div class="phone-case-customizer-wrapper">
  {% if product.tags contains 'dsn-editable-true' %}
    <button id="customize-phone-case-btn" class="customize-btn">
      <span id="button-icon">🎨</span> <span id="button-text">{{ block.settings.button_text }}</span>
    </button>
  {% endif %}

  <!--
    iframe overlay — hidden until the button is clicked.
    position:fixed + 100vw/100vh covers the entire viewport.
    The iframe src is set lazily on first open (avoids loading the app on page load).
  -->
  <div
    id="phone-case-iframe-overlay"
    style="display:none; position:fixed; top:0; left:0; width:100vw; height:100vh; z-index:2147483647; background:#000;"
  >
    <iframe
      id="phone-case-iframe"
      src="about:blank"
      style="width:100%; height:100%; border:none; display:block;"
      allow="camera; microphone; clipboard-write"
      title="Phone Case Customizer"
    ></iframe>
  </div>
</div>

<style>
  .phone-case-customizer-wrapper {
    margin: 20px 0;
    position: relative;
    z-index: 10;
    display: block !important;
    visibility: visible !important;
    opacity: 1 !important;
  }

  .customize-btn {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
    color: white !important;
    border: none !important;
    padding: 15px 30px !important;
    font-size: 16px !important;
    font-weight: 600 !important;
    border-radius: 8px !important;
    cursor: pointer !important;
    transition: transform 0.2s, box-shadow 0.2s !important;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1) !important;
    display: inline-flex !important;
    align-items: center !important;
    gap: 8px !important;
    visibility: visible !important;
    opacity: 1 !important;
    position: relative !important;
    z-index: 10 !important;
    width: auto !important;
    height: auto !important;
    min-width: 200px !important;
  }

  .customize-btn #button-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .customize-btn #button-text {
    display: inline-block;
  }

  .customize-btn:hover {
    transform: translateY(-2px) !important;
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15) !important;
  }

  .customize-btn:active {
    transform: translateY(0) !important;
  }

  /* Hide frame images from product page */
  img[alt='frame' i],
  img[alt='Frame' i],
  img[alt='FRAME' i] {
    display: none !important;
  }
</style>

<script>
  // ── Variant data lookup (Liquid-rendered) ───────────────────────────────────
  var __customizerVariants = {
    {% for variant in product.variants %}
      '{{ variant.id }}': {
        id: '{{ variant.id }}',
        {% if variant.featured_image %}
          backgroundUrl: '{{ variant.featured_image | image_url: width: 600 }}',
          productImageUrl: '{{ variant.featured_image | image_url: width: 600 }}'
        {% elsif product.images.size > 0 %}
          backgroundUrl: '{{ product.images[0] | image_url: width: 600 }}',
          productImageUrl: '{{ product.images[0] | image_url: width: 600 }}'
        {% else %}
          backgroundUrl: '',
          productImageUrl: ''
        {% endif %}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  };

  // Current variant state — updated when the user changes variant on the product page
  var __customizerCurrentVariant = {
    id: '{{ product.selected_or_first_available_variant.id }}',
    backgroundUrl: '{{ background_url }}',
    productImageUrl: '{{ product_image_url }}'
  };

  (function () {
    var overlay = document.getElementById('phone-case-iframe-overlay');
    var iframe  = document.getElementById('phone-case-iframe');
    var btn     = document.getElementById('customize-phone-case-btn');

    if (!overlay || !iframe || !btn) return;

    var iframeLoaded = false;

    // ── Build the iframe src URL ──────────────────────────────────────────────
    function buildEmbedUrl(variantData) {
      var base = window.location.origin + '/apps/customizer/embed';
      var p = new URLSearchParams({
        phoneCaseUrl:        variantData.backgroundUrl   || '',
        productImageUrl:     variantData.productImageUrl || '',
        productImageUrls:    '{{ product_image_urls }}',
        variantId:           variantData.id              || '',
        designsUrl:          '{{ 'pre-design-images.json' | asset_url }}',
        themeColor:          '{{ block.settings.theme_color | default: '#00a8e8' }}',
        productPrice:        '{{ product.selected_or_first_available_variant.price | money }}',
        productComparePrice: '{{ product.selected_or_first_available_variant.compare_at_price | money }}',
        customFrameUrl:      '{{ custom_frame_url }}',
        hasCustomFrame:      '{{ has_custom_frame }}'
      });
      return base + '?' + p.toString();
    }

    // ── Scroll lock (parent page) ─────────────────────────────────────────────
    // When the iframe overlay is visible the parent page must not scroll or PTR.
    // We still lock the parent page even though PTR is now handled inside the
    // iframe, because the parent page can still scroll behind the overlay on
    // some browsers if not locked.
    function lockParentScroll() {
      document.documentElement.style.touchAction = 'none';
      document.documentElement.style.overscrollBehavior = 'none';

      var mainContent = document.getElementById('MainContent');
      if (mainContent) {
        mainContent.style.overscrollBehavior = 'none';
        mainContent.style.touchAction = 'none';
      }

      var scrollY = window.scrollY;
      document.body.dataset.scrollY = scrollY;
      document.body.style.position = 'fixed';
      document.body.style.top = '-' + scrollY + 'px';
      document.body.style.width = '100%';
    }

    function unlockParentScroll() {
      document.documentElement.style.touchAction = '';
      document.documentElement.style.overscrollBehavior = '';

      var mainContent = document.getElementById('MainContent');
      if (mainContent) {
        mainContent.style.overscrollBehavior = '';
        mainContent.style.touchAction = '';
      }

      var scrollY = parseInt(document.body.dataset.scrollY || '0', 10);
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.width = '';
      delete document.body.dataset.scrollY;
      window.scrollTo(0, scrollY);
    }

    // ── Open / close ──────────────────────────────────────────────────────────
    function openCustomizer() {
      // Lazy-load the iframe on first open
      if (!iframeLoaded) {
        iframe.src = buildEmbedUrl(__customizerCurrentVariant);
        iframeLoaded = true;
      }
      overlay.style.display = 'block';
      lockParentScroll();
    }

    function closeCustomizer() {
      overlay.style.display = 'none';
      unlockParentScroll();
    }

    btn.addEventListener('click', openCustomizer);

    // ── postMessage: receive messages FROM the iframe ─────────────────────────
    window.addEventListener('message', function (e) {
      if (!e.data || typeof e.data.type !== 'string') return;

      if (e.data.type === 'customizer:close') {
        closeCustomizer();
      }

      if (e.data.type === 'customizer:addToCart') {
        handleAddToCart(e.data.detail);
      }
    });

    // ── Add to Cart (runs on the parent page — same origin as Shopify) ────────
    async function handleAddToCart(detail) {
      var designId      = detail.designId;
      var imageUrl      = detail.imageUrl;
      var emptyCaseUrl  = detail.emptyCaseUrl;
      var designOnlyUrl = detail.designOnlyUrl;
      var elementUrls   = detail.elementUrls || [];
      var variantId     = __customizerCurrentVariant.id
                          || '{{ product.selected_or_first_available_variant.id }}';

      if (!variantId) {
        alert('Please select a product variant first.');
        return;
      }

      var properties = {
        _design_id:     designId,
        _main:          imageUrl,
        _image1:        emptyCaseUrl,
        '_print-image': designOnlyUrl,
        'Düzenlendi':   'Evet',
        'Tasarım':      imageUrl
      };

      elementUrls.forEach(function (url, index) {
        properties['_element' + (index + 1)] = url;
      });

      var formData = {
        items: [{
          id:         variantId,
          quantity:   1,
          properties: properties,
          image:      imageUrl
        }]
      };

      try {
        var response = await fetch('/cart/add.js', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify(formData)
        });

        if (response.ok) {
          closeCustomizer();
          window.location.href = '/cart';
        } else {
          var error = await response.json();
          alert('Failed to add to cart: ' + (error.description || error.message || 'Unknown error'));
        }
      } catch (err) {
        console.error('Failed to add to cart:', err);
        alert('Failed to add to cart. Please try again.');
      }
    }

    // ── Variant change: forward to iframe via postMessage ─────────────────────
    function notifyIframeVariantChanged(variantData) {
      __customizerCurrentVariant = variantData;
      if (iframeLoaded && iframe.contentWindow) {
        iframe.contentWindow.postMessage(
          { type: 'customizer:variantChanged', detail: variantData },
          '*'
        );
      }
    }

    // Listen for Shopify theme variant change events
    document.addEventListener('variant:change', function (event) {
      if (event.detail && event.detail.variant && event.detail.variant.id) {
        var vd = __customizerVariants[event.detail.variant.id.toString()];
        if (vd) notifyIframeVariantChanged(vd);
      }
    });

    // Variant selector (select / hidden input)
    document.querySelectorAll('select[name="id"], input[name="id"]').forEach(function (el) {
      el.addEventListener('change', function (e) {
        var vd = __customizerVariants[e.target.value];
        if (vd) notifyIframeVariantChanged(vd);
      });
    });

    // Radio buttons (modern themes)
    document.querySelectorAll('input[type="radio"][name*="option"]').forEach(function (radio) {
      radio.addEventListener('change', function () {
        setTimeout(function () {
          var sel = document.querySelector('input[name="id"]:checked, select[name="id"]');
          if (sel) {
            var vid = sel.value || (sel.options && sel.options[sel.selectedIndex].value);
            var vd = __customizerVariants[vid];
            if (vd) notifyIframeVariantChanged(vd);
          }
        }, 50);
      });
    });
  })();
</script>

<script>
  // ── Button appearance from admin settings ───────────────────────────────────
  (function () {
    var customizeBtn = document.getElementById('customize-phone-case-btn');
    var buttonIcon = document.getElementById('button-icon');
    var buttonText = document.getElementById('button-text');

    fetch(window.location.origin + '/apps/customizer/get-settings')
      .then(function (r) {
        return r.json();
      })
      .then(function (data) {
        if (customizeBtn && data.buttonColor) {
          var c = data.buttonColor;
          customizeBtn.style.setProperty(
            'background',
            'linear-gradient(135deg, ' + c + ' 0%, ' + c + 'dd 100%)',
            'important'
          );
        }
        if (buttonText && data.buttonText) {
          buttonText.textContent = data.buttonText;
        }
        if (buttonIcon) {
          if (data.buttonLogoUrl) {
            buttonIcon.innerHTML =
              '<img src="' +
              data.buttonLogoUrl +
              '" alt="Logo" ' +
              'style="width:20px;height:20px;object-fit:contain;vertical-align:middle;">';
          } else {
            buttonIcon.textContent = '🎨';
          }
        }
      })
      .catch(function () {});
  })();
</script>

<script>
  // ── Hide "frame" product images from the storefront gallery ────────────────
  (function () {
    function hideFrameImages() {
      document
        .querySelectorAll('li.product-media-container, li[class*="product-media"], li[class*="media"]')
        .forEach(function (container) {
          var img = container.querySelector('img');
          if (img && img.getAttribute('alt') && img.getAttribute('alt').toLowerCase() === 'frame') {
            container.style.cssText =
              'display:none!important;visibility:hidden;opacity:0;height:0;width:0;overflow:hidden;position:absolute;';
          }
        });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', hideFrameImages);
    } else {
      hideFrameImages();
    }
    [100, 500, 1000, 2000].forEach(function (t) {
      setTimeout(hideFrameImages, t);
    });

    new MutationObserver(hideFrameImages).observe(document.body, {
      childList: true,
      subtree: true,
      attributes: true,
      attributeFilter: ['alt'],
    });
  })();
</script>

{% schema %}
{
  "name": "Phone Case Customizer",
  "target": "section",
  "settings": []
}
{% endschema %}
