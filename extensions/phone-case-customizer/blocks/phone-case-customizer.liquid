<script>
// Remove frame images and their parent containers from product page
(function() {
  let lastVariantId = null;
  
  function hideFrameImages() {
    console.log('Searching for frame images to hide...');
    
    // Check if variant changed by looking at URL
    const urlParams = new URLSearchParams(window.location.search);
    const currentVariantId = urlParams.get('variant');
    
    if (currentVariantId && currentVariantId !== lastVariantId) {
      console.log('Variant changed detected! Old:', lastVariantId, 'New:', currentVariantId);
      lastVariantId = currentVariantId;
      
      // Update the customizer root element with new variant
      const rootElement = document.getElementById('phone-case-root');
      if (rootElement) {
        // Trigger variant update by directly calling the update function
        const event = new CustomEvent('variant:change', {
          detail: { variant: { id: currentVariantId } }
        });
        document.dispatchEvent(event);
      }
    }
    
    // Find all product media containers (li elements)
    const mediaContainers = document.querySelectorAll('li.product-media-container, li[class*="product-media"], li[class*="media"]');
    
    console.log('Found', mediaContainers.length, 'media containers');
    
    mediaContainers.forEach(container => {
      // Check if this container has an image with alt="frame"
      const img = container.querySelector('img');
      if (img) {
        const alt = img.getAttribute('alt');
        if (alt && alt.toLowerCase() === 'frame') {
          console.log('Found frame image in container, hiding:', container);
          container.style.display = 'none';
          container.style.visibility = 'hidden';
          container.style.opacity = '0';
          container.style.height = '0';
          container.style.width = '0';
          container.style.overflow = 'hidden';
          container.style.position = 'absolute';
        }
      }
    });
  }
  
  // Run on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', hideFrameImages);
  } else {
    hideFrameImages();
  }
  
  // Run again after delays to catch dynamically loaded images
  setTimeout(hideFrameImages, 100);
  setTimeout(hideFrameImages, 500);
  setTimeout(hideFrameImages, 1000);
  setTimeout(hideFrameImages, 2000);
  
  // Watch for DOM changes
  const observer = new MutationObserver(function(mutations) {
    hideFrameImages();
  });
  
  observer.observe(document.body, { 
    childList: true, 
    subtree: true,
    attributes: true,
    attributeFilter: ['alt']
  });
})();
</script>

<script>
(function() {
  const modal = document.getElementById('phone-case-modal');
  const btn = document.getElementById('customize-phone-case-btn');
  
  if (!modal || !btn) {
    console.error('Modal or button not found:', { modal, btn });
    return;
  }
  
  let reactMounted = false;
  let modalMovedToBody = false;
  
  // Move modal to body on first open to escape theme container
  function ensureModalInBody() {
    if (!modalMovedToBody && modal && modal.parentElement !== document.body) {
      document.body.appendChild(modal);
      modalMovedToBody = true;
    }
  }
  
  // Open modal
  btn.addEventListener('click', function() {
    console.log('Customize button clicked');
    ensureModalInBody();
    modal.style.visibility = 'visible';
    modal.style.opacity = '1';
    document.body.style.overflow = 'hidden';
    
    // Mount React app on first open
    if (!reactMounted && window.React && window.ReactDOM) {
      reactMounted = true;
      // The phone-customizer.js will auto-mount when the element is visible
    }
  });
  
  // Close modal function (called by backdrop click)
  function closeModal() {
    modal.style.visibility = 'hidden';
    modal.style.opacity = '0';
    document.body.style.overflow = '';
    // Unmount React app
    const root = document.getElementById('phone-case-root');
    if (root && window.ReactDOM) {
      window.ReactDOM.unmountComponentAtNode(root);
    }
  }
  
  // Close button is now handled by React component
  // Clicking outside the content area closes modal
  modal.addEventListener('click', function(e) {
    if (e.target === modal) {
      closeModal();
    }
  });
  
  // Handle Add to Cart from customizer
  window.addEventListener('customizer:addToCart', async function(e) {
    const { designId, imageUrl, emptyCaseUrl, designOnlyUrl, elementUrls } = e.detail;
    
    console.log('Add to cart event received:', { designId, imageUrl, emptyCaseUrl, designOnlyUrl, elementUrls });
    
    // Get the current variant ID from the root element (updated by variant change listener)
    const rootElement = document.getElementById('phone-case-root');
    const variantId = rootElement ? rootElement.getAttribute('data-variant-id') : '{{ product.selected_or_first_available_variant.id }}';
    
    console.log('Variant ID:', variantId);
    
    if (!variantId || variantId === '') {
      alert('Please select a product variant first.');
      return;
    }
    
    // Build cart properties with element URLs
    const properties = {
      '_design_id': designId,
      '_main': imageUrl,
      '_image1': emptyCaseUrl,
      '_print-image': designOnlyUrl,
      'Düzenlendi': 'Evet',
      'Tasarım': imageUrl  // Visible property showing the complete design URL
    };
    
    // Add element URLs to properties
    if (elementUrls && elementUrls.length > 0) {
      elementUrls.forEach((url, index) => {
        properties[`_element${index + 1}`] = url;
      });
      console.log(`Added ${elementUrls.length} element URLs to cart properties`);
    }
    
    // Add to Shopify cart
    const formData = {
      items: [{
        id: variantId,
        quantity: 1,
        properties: properties,
        // Set the custom image as the line item image
        image: imageUrl
      }]
    };
    
    console.log('Cart add request:', formData);
    
    try {
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });
      
      console.log('Cart add response status:', response.status);
      
      if (response.ok) {
        const data = await response.json();
        console.log('Cart add success:', data);
        
        closeModal();
        
        // Redirect to cart page
        window.location.href = '/cart';
      } else {
        const error = await response.json();
        console.error('Cart add error:', error);
        alert('Failed to add to cart: ' + (error.description || error.message || 'Unknown error'));
      }
    } catch (error) {
      console.error('Failed to add to cart:', error);
      alert('Failed to add to cart. Please try again.');
    }
  });
})();
</script>

